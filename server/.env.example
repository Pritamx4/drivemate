# MongoDB Connection String
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/drivemate

# Server Port
PORT=5000

# JWT Secret for token authentication (generate a strong random string)
JWT_SECRET=your_jwt_secret_key_here

# Owner WhatsApp Contact Number (for customer support)
OWNER_WHATSAPP=+919876543210

# Comma-separated allowed frontend origins for CORS
CORS_ORIGIN=http://localhost:5173,https://your-frontend-name.onrender.com
